{
  "name": "ad-vantage",
  "version": "1.3.3",
  "description": "Chrome extension to enhance the Vantage timesheet app",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
